# History files
.Rhistory
.Rapp.history

# Session Data files
.RData
.RDataTmp

# User-specific files
.Ruserdata

# Example code in package build process
*-Ex.R

# Output files from R CMD build
/*.tar.gz

# Output files from R CMD check
/*.Rcheck/

# RStudio files
.Rproj.user/

# produced vignettes
vignettes/*.html
vignettes/*.pdf

# OAuth2 token, see https://github.com/hadley/httr/releases/tag/v0.3
.httr-oauth

# knitr and R markdown default cache directories
*_cache/
/cache/

# Temporary files created by R markdown
*.utf8.md
*.knit.md

# R Environment Variables
.Renviron

# pkgdown site
docs/

# translation temp files
po/*~

# RStudio Connect folder
rsconnect/

# Local data, generated output, and private references
data/*
!data/.gitkeep
output/*
!output/.gitkeep
references/private/

# Local credentials and editor files
.env
.DS_Store
*.swp
*~
/doc/
/Meta/

# Private company-data work. Real modeling datasets and any source-derived
# output must never be committed. Ignore everything under scripts_private/ EXCEPT
# the template code and docs and possible example scripts.
# A parent-directory ignore would hide the whole
# tree from git and defeat the re-includes below, so ignore by content instead.
/scripts_private/**
!/scripts_private/
!/scripts_private/.gitignore
!/scripts_private/README.md
!/scripts_private/try_dp_calibrated.R
!/scripts_private/try_avatar.R
!/scripts_private/try_avatar_pit565.R
!/scripts_private/try_avatar_pit565.qmd

# Local Claude Code settings
.claude/
